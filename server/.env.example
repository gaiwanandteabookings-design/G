# Скопируйте этот файл в .env и заполните реальными значениями перед запуском в проде.

PORT=3000

# Ставьте в production, когда сайт реально задеплоен (включает редирект http->https).
NODE_ENV=development

# Ставьте true только если сайт работает за реверс-прокси/хостингом (Render, Railway,
# nginx и т.д.), который сам выставляет заголовки X-Forwarded-*. Иначе оставьте пустым.
TRUST_PROXY=

# Логин/пароль для входа в /admin.html (заявки, инвойсы). ОБЯЗАТЕЛЬНО смените на что-то
# надёжное перед реальным запуском — короткий числовой пароль легко подобрать перебором.
ADMIN_USERNAME=profix305
ADMIN_PASSWORD=1234

# Google Analytics 4 Measurement ID (вида G-XXXXXXX). Оставьте пустым, чтобы аналитика
# на сайт не подключалась вообще.
GA_MEASUREMENT_ID=

# --- Email (уведомления о заявках + отправка инвойсов) ---
# Письма отправляются через SendGrid API (HTTPS), а НЕ через обычный SMTP — на Render
# бесплатный план блокирует исходящий SMTP (порты 25/465/587) полностью, соединение
# просто зависает навсегда. SendGrid шлёт письма как обычный HTTPS-запрос, это не блокируется.
# Если SENDGRID_API_KEY не задан, письма просто не отправляются, заявки/инвойсы всё равно
# сохраняются в БД.
#
# Как настроить (один раз, 5 минут):
# 1. Зарегистрируйся на sendgrid.com (бесплатный план — 100 писем/день).
# 2. Settings -> Sender Authentication -> Single Sender Verification -> добавь
#    profix305@gmail.com, подтверди по ссылке из письма (не нужен свой домен).
# 3. Settings -> API Keys -> Create API Key -> Full Access -> скопируй ключ (виден один раз).
SENDGRID_API_KEY=
# Куда присылать уведомления о новой брони:
NOTIFY_EMAIL=profix305@gmail.com
# От чьего имени отправлять — ДОЛЖЕН совпадать с адресом, подтверждённым в Single Sender Verification:
FROM_EMAIL="ProFix305 <profix305@gmail.com>"

# --- База данных (Turso — бесплатная, переживает передеплой) ---
# Без этих двух переменных БД живёт в локальном файле server/data/bookings.db — это ок
# для локальной разработки, но на Render бесплатном тарифе этот файл стирается при
# каждом передеплое (все заявки/инвойсы пропадают). Как настроить — см. README.md
# ("Making bookings/invoices survive redeploys").
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
