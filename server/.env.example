# Скопируйте этот файл в .env и заполните реальными значениями перед запуском в проде.

PORT=3000

# Токен для доступа к /admin.html и защищённым admin API. Придумайте длинную случайную строку.
ADMIN_TOKEN=change-me-to-a-long-random-string

# --- Email-уведомления о новых заявках (необязательно) ---
# Если SMTP_HOST не задан, письма просто не отправляются, заявки всё равно сохраняются в БД.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Куда присылать уведомления о новой брони:
NOTIFY_EMAIL=booking@coldchain305.com
# От чьего имени отправлять:
FROM_EMAIL="ColdChain305 Website <no-reply@coldchain305.com>"
