# Скопируйте этот файл в .env и заполните реальными значениями перед запуском в проде.

PORT=3000

# Ставьте в production, когда сайт реально задеплоен (включает редирект http->https).
NODE_ENV=development

# Ставьте true только если сайт работает за реверс-прокси/хостингом (Render, Railway,
# nginx и т.д.), который сам выставляет заголовки X-Forwarded-*. Иначе оставьте пустым.
TRUST_PROXY=

# Логин/пароль для входа в /admin.html (заявки, инвойсы). ОБЯЗАТЕЛЬНО смените на что-то
# надёжное перед реальным запуском — короткий числовой пароль легко подобрать перебором.
ADMIN_USERNAME=profix305
ADMIN_PASSWORD=1234

# Google Analytics 4 Measurement ID (вида G-XXXXXXX). Оставьте пустым, чтобы аналитика
# на сайт не подключалась вообще.
GA_MEASUREMENT_ID=

# --- Email (уведомления о заявках + отправка инвойсов) ---
# Если SMTP_HOST не задан, письма просто не отправляются, заявки/инвойсы всё равно
# сохраняются в БД. Настроено под Gmail (profix305@gmail.com) — SMTP_PASS должен быть
# "App Password" (пароль приложения), НЕ обычный пароль от аккаунта Google:
# 1. Включи двухфакторную аутентификацию: myaccount.google.com/security
# 2. Создай пароль приложения: myaccount.google.com/apppasswords
# 3. Вставь получившиеся 16 символов сюда без пробелов
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=profix305@gmail.com
SMTP_PASS=
# Куда присылать уведомления о новой брони:
NOTIFY_EMAIL=profix305@gmail.com
# От чьего имени отправлять:
FROM_EMAIL="ProFix305 <profix305@gmail.com>"
